# ============================================
# ShortURLPro 环境变量配置文件 (.env)
# ============================================

# 数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/short_url_db?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true
MYSQL_USERNAME=short_url_db
MYSQL_PASSWORD=123456

# Redis配置（可选）
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 管理员密码
ADMIN_PASSWORD=admin123

# 应用基础URL
SHORT_URL_BASE_URL=http://localhost:8080

# 应用端口
SERVER_PORT=8080

# 激活的配置文件
SPRING_PROFILES_ACTIVE=dev

# JWT密钥（建议在生产环境中更改）
JWT_SECRET=mySecretKeyForShortURLProApplication2024

# 日志级别
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE_SHORTURLPRO=DEBUG